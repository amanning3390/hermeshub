# HermesHub Environment Variables
# Copy to .env (local dev) or set in Vercel Project Settings for production.

# ── Database ──────────────────────────────────────────────────────────────────
# Neon Postgres connection string (serverless HTTP driver).
DATABASE_URL=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Stripe API secret. Start with test key; swap to live at cutover.
STRIPE_SECRET_KEY=
# Stripe publishable key (client/checkout).
STRIPE_PUBLISHABLE_KEY=
# Signing secret for the Stripe webhook endpoint.
STRIPE_WEBHOOK_SECRET=

# ── Platform ──────────────────────────────────────────────────────────────────
# Public origin, e.g. https://hermeshub.xyz
BASE_URL=
# Secret used to sign session cookies.
SESSION_SECRET=

# ── GitHub OAuth (optional for demo — anonymous sign-in works without it) ─────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
